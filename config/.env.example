# C.Y.R.U.S — Environment variable template
# Copy to .env and fill in your values.
# The application loads this file automatically via python-dotenv.

# ── Required only when mode == HYBRID ────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────
CYRUS_LOG_LEVEL=INFO
CYRUS_HOME=~/.cyrus

# ── Ollama location (if running on a different host) ─────────────────────────
OLLAMA_HOST=http://localhost:11434
